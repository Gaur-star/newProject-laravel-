*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: arial, halvetica, sans-serif;
}

body{
    height: 100vh;
    background: linear-gradient(135deg, #4facfe, #00f2fe);
    display: flex;
    justify-content: center;
    align-items: center;
}

.login-box{
    background: white;
    padding: 40px;
    width: 320px;
    border-radius: 10px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    text-align: center;
}